          },
          "previewData": {
            "description": "Preview of the first N rows of the file.",
            "items": {
              "description": "Preview of the first N rows of the file.",
              "items": {
                "description": "Preview of the first N rows of the file.",
                "type": "object"
              },
              "type": "array"
            },
            "type": "array"
          }
        },
        "required": [
          "columns",
          "location",
          "previewData"
        ],
        "type": "object"
      },
      "AnalyzeCsvResponseColumn": {
        "description": "Describes the result column.",
